{
  "name": "dalyhub-v2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "vite preview --port 4173 --strictPort",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "test": "pnpm run test:unit && pnpm run test:kernel",
    "test:unit": "vitest run",
    "test:kernel": "vitest run --config ./vitest.workers.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run test:e2e",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:dry-run": "pnpm run build && wrangler deploy --dry-run --config build/server/wrangler.json",
    "cf-typegen": "wrangler types",
    "db:migrations:list:local": "wrangler d1 migrations list DB --local",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "isbot": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.0",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@react-router/dev": "8.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/hast": "3.0.5",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}
